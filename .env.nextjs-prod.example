# EUS Support — Next.js Production Environment
# Copy to .env.nextjs-prod and fill in actual values.
# This file is referenced by docker-compose.nextjs-prod.yml.

NODE_ENV=production

# Authentication
AUTH_PROVIDER=legacy
SESSION_SECRET=
SESSION_MAX_AGE_SECONDS=28800

# Write operations enabled in production
WRITES_ENABLED=true
NEXT_PUBLIC_WRITES_ENABLED=true

# Environment label shown in UI
NEXT_PUBLIC_ENV_LABEL=production

# SMTP (required for RMA notification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Database connection is set via docker-compose environment block using
# INVENTORY_PG_USER, INVENTORY_PG_PASSWORD, INVENTORY_PG_DB from the
# existing .env file. No need to duplicate DATABASE_URL here.
