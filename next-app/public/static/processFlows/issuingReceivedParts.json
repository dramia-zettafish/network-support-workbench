      "role": "Parts Administrator",
      "system": "Dynamics",
      "details": [
        "Click \"Next Stage\" to move the case to the Repair stage."
      ],
      "tags": ["Dynamics", "Repair"],
      "step": "3",
      "stepOrder": 3,
      "position": { "x": 0, "y": 240 }
    },
    {
