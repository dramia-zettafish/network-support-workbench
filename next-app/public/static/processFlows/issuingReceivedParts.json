      "type": "action",
      "label": "Set \"Issuing Parts\" = Yes",
      "role": "Parts Administrator",
      "system": "Dynamics",
      "details": [
        "Update the case to indicate parts are being issued."
      ],
      "tags": ["Dynamics", "Parts", "Repair"],
      "step": "2",
      "stepOrder": 2,
      "position": { "x": 0, "y": 120 }
    },
    {
      "id": "step-1-3",
      "type": "action",
