# Environment Variables for EUS Support Next.js App
# Copy this file to .env.local and adjust values as needed.
# .env.local is NOT committed to version control.

# Environment label displayed in the UI and returned by /api/env-label
NEXT_PUBLIC_ENV_LABEL=development

# ─────────────────────────────────────────────────────────────────────────────
# Authentication Provider Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Supported values: mock, legacy, duo (future)
# - mock: Development only — accepts any credentials, returns mock user.
#         REJECTED in production (NODE_ENV=production). Fails closed.
# - legacy: Interim production auth — bcrypt password verification against
#           auth_users table. Requires SESSION_SECRET.
# - duo: Future Cisco Duo MFA integration (not yet implemented).
AUTH_PROVIDER=mock

# Session signing secret. REQUIRED for legacy provider.
# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-generate-a-real-secret-at-least-32-chars

# Session lifetime in seconds (default: 28800 = 8 hours)
SESSION_MAX_AGE_SECONDS=28800

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL Read-Only Connection (added by transformation)
# ─────────────────────────────────────────────────────────────────────────────
# Preferred: full connection string (set ONE of DATABASE_URL or DB_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/your_database_name
DB_URL=postgresql://user:password@localhost:5432/your_database_name

# Network Workbench database. This must be separate from DATABASE_URL.
# The hosted workbench code intentionally never falls back to DATABASE_URL.
NETWORK_DATABASE_URL=postgresql://network:network@localhost:15433/network_workbench_local
NEXT_PUBLIC_NETWORK_ROUTE_PREFIX=/network
NEXT_PUBLIC_NETWORK_API_BASE=/api/network

# Individual fallback variables (used only if DATABASE_URL and DB_URL are not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_SSL=false

# Comma-separated list of tables allowed for read queries
# cm_cases is required for the /api/cases endpoint
DB_ALLOWED_TABLES=parts_catalog,inventory,cm_cases,cm_case_workflow_rma,cm_case_notes,cm_case_requirements,users,teams

# ─────────────────────────────────────────────────────────────────────────────
# Write Safety Foundation — Environment Flags
# ─────────────────────────────────────────────────────────────────────────────
# Server-side write enforcement flag.
# Controls whether write API routes (POST, PUT, PATCH, DELETE) accept requests.
# When set to 'false' (default), all write operations are rejected with a 403 response.
# This is the AUTHORITATIVE gate — even if the client flag is enabled, the server
# will still block writes unless this flag is explicitly set to 'true'.
WRITES_ENABLED=false

# Client-side display flag.
# Controls whether the UI shows write capabilities (form buttons, edit actions)
# or displays a read-only notice to users.
# When set to 'false' (default), the WriteDisabledNotice component is shown
# informing users that write operations are not yet available.
# NOTE: This is a UI convenience only — the server-side WRITES_ENABLED flag
# is the actual enforcement mechanism.
NEXT_PUBLIC_WRITES_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# SMTP Email Configuration (for notification sending)
# ─────────────────────────────────────────────────────────────────────────────
# Required for sending RMA notification emails.
# If not configured, the send endpoint returns HTTP 503.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=eussupport@example.com
