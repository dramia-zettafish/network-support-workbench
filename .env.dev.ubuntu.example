# Ubuntu/Linux host metric paths.
# Copy these into .env.dev on Ubuntu, then run:
#   sh dev/write-system-metrics.sh /tmp/eusupport-system-metrics.json 1 &
#
# Docker will mount / read-only at /host-storage, so the host snapshot at
# /tmp/eusupport-system-metrics.json is visible inside the container at:
# /host-storage/tmp/eusupport-system-metrics.json

# ── Dev Database (required by docker-compose.dev.yml) ──
# These use DEV_* prefixes to prevent accidental production credential inheritance.
DEV_INVENTORY_PG_DB=inventory_dev
DEV_INVENTORY_PG_USER=inventory_dev
DEV_INVENTORY_PG_PASSWORD=dev_change_me_now
DEV_INVENTORY_PG_PASSWORD_URLENCODED=dev_change_me_now

# ── System Metrics ──
SYSTEM_METRICS_STORAGE_SOURCE=/
SYSTEM_METRICS_STORAGE_PATH=/host-storage
SYSTEM_METRICS_HOST_SNAPSHOT_PATH=/host-storage/tmp/eusupport-system-metrics.json
SYSTEM_METRICS_COLLECTOR_USERNAME=DEV User
SYSTEM_METRICS_COLLECTOR_ROLE=manager
SYSTEM_METRICS_COLLECTOR_INTERVAL_MS=1000
