# EUSupport-hosted Network Workbench local stack.
# Copy to .env.local before running docker compose.

APP_PORT=18004
NEXT_PUBLIC_ENV_LABEL=local

# Generate a replacement with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=local-dev-session-secret-change-me-32chars
SESSION_MAX_AGE_SECONDS=28800

# EUSupport sanitized database.
LOCAL_EUSUPPORT_DB_PORT=15432
LOCAL_EUSUPPORT_PG_DB=eusupport_local
LOCAL_EUSUPPORT_PG_USER=eusupport
LOCAL_EUSUPPORT_PG_PASSWORD=eusupport

# Network Workbench database. This must stay separate from DATABASE_URL.
LOCAL_NETWORK_DB_PORT=15433
LOCAL_NETWORK_PG_DB=network_workbench_local
LOCAL_NETWORK_PG_USER=network
LOCAL_NETWORK_PG_PASSWORD=network

# Optional SMTP placeholders.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=
SMTP_TLS=
